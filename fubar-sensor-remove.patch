+test("sensor remove deletes a sensor from listings", async () => {
+  expect((await run(["home", "create", "Sensor Remove Home"])).exitCode).toBe(0);
+  expect((await run(["room", "add", "lab", "--home", "Sensor Remove Home"])).exitCode).toBe(0);
+  expect((await run(["sensor", "add", "lab", "motion", "lab-motion"])).exitCode).toBe(0);
+
+  const before = await run(["--json", "sensor", "list", "--room", "lab"]);
+  expect(before.exitCode).toBe(0);
+  expect(JSON.parse(before.stdout).data.map((sensor: { name: string }) => sensor.name)).toContain("lab-motion");
+
+  expect((await run(["sensor", "remove", "lab-motion"])).exitCode).toBe(0);
+
+  const after = await run(["--json", "sensor", "list", "--room", "lab"]);
+  expect(after.exitCode).toBe(0);
+  expect(JSON.parse(after.stdout).data.map((sensor: { name: string }) => sensor.name)).not.toContain("lab-motion");
+});
